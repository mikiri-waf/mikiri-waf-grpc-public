ngx_addon_name=mikiri_waf_grpc_module

WAF_SRCS="                                      \
           $ngx_addon_dir/mikiri_waf_grpc_module.c  \
           $ngx_addon_dir/waf_grpc_parse.c            \
           $ngx_addon_dir/waf_grpc_process.c            \
           $ngx_addon_dir/waf_rules.c            \
           $ngx_addon_dir/waf_request_parser.c       \
           $ngx_addon_dir/waf_exchange.c               \
           $ngx_addon_dir/waf_shared_contexts.c     \
           $ngx_addon_dir/waf_connections.c     \
           $ngx_addon_dir/waf_memory.c     \
           "
WAF_DEPS="                                      \
           $ngx_addon_dir/mikiri_waf_grpc_module.h  \
           $ngx_addon_dir/mikiri_waf_http_module.h  \
           $ngx_addon_dir/waf_grpc_parse.h            \
           $ngx_addon_dir/waf_grpc_process.h            \
           $ngx_addon_dir/waf_request_parser.h       \
           $ngx_addon_dir/waf_exchange.h               \
           $ngx_addon_dir/waf_shared_contexts.h     \
           $ngx_addon_dir/waf_connections.h     \
           $ngx_addon_dir/waf_memory.h     \
           "

WAF_CORE_LIBS="-lcurl -lrabbitmq -lmemcached"

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=mikiri_waf_grpc_module
    ngx_module_srcs=$WAF_SRCS
    ngx_module_deps=$WAF_DEPS
    ngx_module_libs=$WAF_CORE_LIBS
    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES $ngx_addon_name"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $WAF_SRCS"
    NGX_ADDON_DEPS="$NGX_ADDON_DEPS $WAF_DEPS"
    CORE_LIBS="$CORE_LIBS $WAF_CORE_LIBS"
fi
